{
  "manifest_version": 3,
  "name": "Daily English Tab",
  "version": "1.3.2",
  "description": "English learning popup with daily sentences, review queue, speech playback, and automatic GitHub sync.",
  "action": {
    "default_title": "Daily English Tab",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "alarms"]
}
